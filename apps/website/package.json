{
	"name": "@open-bento/website",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "biome lint .",
		"format": "biome lint --write .",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "pnpx https://pkg.pr.new/better-auth/better-auth/@better-auth/cli@6913 generate --config src/lib/server/auth.ts --output src/lib/server/db/schema/auth.db.ts --yes",
		"auth:schema:notes": "https://github.com/better-auth/better-auth/issues/6766"
	},
	"devDependencies": {
		"@better-auth/drizzle-adapter": "https://pkg.pr.new/better-auth/better-auth/@better-auth/drizzle-adapter@6913",
		"@biomejs/biome": "catalog:",
		"@libsql/client": "^0.17.3",
		"@open-bento/config": "workspace:",
		"@open-bento/types": "workspace:",
		"@orpc/client": "catalog:",
		"@orpc/openapi": "catalog:",
		"@orpc/openapi-client": "catalog:",
		"@orpc/server": "catalog:",
		"@orpc/tanstack-query": "catalog:",
		"@paralleldrive/cuid2": "^3.3.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@tanstack/svelte-query": "catalog:",
		"better-auth": "^1.6.9",
		"drizzle-kit": "beta",
		"drizzle-orm": "beta",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"zod": "catalog:"
	}
}